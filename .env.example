# Supabase — browser-safe (PUBLIC_ prefix is exposed to the client).
# The anon key is public by design; RLS is the security boundary.
PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# The designated public showcase profile (read-only surface). Set once a
# showcase profile exists. Exposed to the client for showcase routing only.
PUBLIC_SHOWCASE_PROFILE_ID=""

# Server-only — NEVER ship to the client. Lives in Supabase Edge Function /
# Railway env only. Not read by the Astro client build.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
