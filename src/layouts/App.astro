---
import Base from './Base.astro';

interface Props {
  title?: string;
  // Read-only public showcase: swaps the nav to the /showcase/* surfaces (which
  // mount no write affordances) and shows a "sign in" CTA instead of app tools.
  showcase?: boolean;
}

const { title = 'Verocity', showcase = false } = Astro.props;
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const home = showcase ? '/showcase' : '/app';
const links = showcase
  ? [
      { href: '/showcase', label: 'Home' },
      { href: '/showcase/calendar', label: 'Calendar' },
      { href: '/showcase/stats', label: 'Stats' },
      { href: '/showcase/plan', label: 'Plan' },
      { href: '/showcase/library', label: 'Library' },
    ]
  : [
      { href: '/app', label: 'Home' },
      { href: '/app/calendar', label: 'Calendar' },
      { href: '/app/stats', label: 'Stats' },
      { href: '/app/coach', label: 'Coach' },
      { href: '/app/plan', label: 'Plan' },
      { href: '/app/sessions', label: 'Sessions' },
      { href: '/app/library', label: 'Library' },
      { href: '/app/shares', label: 'Share' },
    ];
const isActive = (href: string) => (href === home ? path === home : path.startsWith(href));
---

<Base title={title}>
  <a href="#main" class="skip-link">Skip to content</a>
  <header class="sticky top-0 z-50 border-b border-border bg-bg/90 backdrop-blur-md">
    <div class="mx-auto flex h-16 max-w-3xl items-center justify-between px-6">
      <button
        id="nav-toggle"
        type="button"
        aria-expanded="false"
        aria-controls="nav-menu"
        class="flex items-center gap-2.5 text-fg"
      >
        <span class="flex flex-col gap-[5px]" aria-hidden="true">
          <span class="block h-[2px] w-5 bg-fg"></span>
          <span class="block h-[2px] w-5 bg-fg"></span>
          <span class="block h-[2px] w-5 bg-fg"></span>
        </span>
        <span class="font-display text-lg font-semibold uppercase tracking-tight">Verocity</span>
      </button>
      {
        showcase && (
          <div class="flex items-center gap-3">
            <span class="hidden text-[0.6rem] uppercase tracking-[0.18em] text-muted sm:inline">
              Read-only showcase
            </span>
            <a
              href="/login"
              class="inline-flex h-9 items-center rounded-full border border-fg px-4 text-xs uppercase tracking-wider text-fg transition-colors duration-200 hover:bg-fg hover:text-bg"
            >
              Sign in
            </a>
          </div>
        )
      }
    </div>
  </header>

  <div id="nav-backdrop" class="fixed inset-0 z-[60] hidden"></div>

  <nav
    id="nav-menu"
    aria-label="Primary"
    class="fixed left-0 top-0 z-[70] h-dvh w-64 -translate-x-full border-r border-border bg-bg/90 shadow-2xl backdrop-blur-xl transition-transform duration-300 ease-[cubic-bezier(0.77,0,0.175,1)]"
  >
    <div class="flex h-16 items-center px-6">
      <span class="font-display text-lg font-semibold uppercase tracking-tight text-fg">Verocity</span>
    </div>
    <div class="px-3 py-2">
      {
        links.map((l) => (
          <a
            href={l.href}
            data-nav-link
            aria-current={isActive(l.href) ? 'page' : undefined}
            class:list={[
              'block px-3 py-2.5 text-sm uppercase tracking-wider transition-colors duration-150 hover:text-fg',
              isActive(l.href) ? 'text-fg' : 'text-muted',
            ]}
          >
            {l.label}
          </a>
        ))
      }
    </div>
    {
      showcase && (
        <div class="mt-2 border-t border-border px-6 py-4">
          <p class="text-[0.7rem] leading-relaxed text-muted">
            You're viewing a read-only demo profile. Nothing here can be edited.
          </p>
          <a
            href="/login"
            class="mt-3 inline-flex h-10 items-center rounded-full bg-fg px-5 text-xs uppercase tracking-wider text-bg transition-transform duration-200 hover:scale-[1.03]"
          >
            Start your own
          </a>
        </div>
      )
    }
  </nav>

  <main id="main"><slot /></main>
</Base>

<script>
  // ClientRouter swaps the DOM between pages, so handlers must rebind on every
  // astro:page-load — otherwise the burger goes dead after the first navigation.
  let ac: AbortController | null = null;

  function setupNav() {
    ac?.abort();
    ac = new AbortController();
    const { signal } = ac;

    const toggle = document.getElementById('nav-toggle');
    const menu = document.getElementById('nav-menu');
    const backdrop = document.getElementById('nav-backdrop');
    if (!toggle || !menu || !backdrop) return;

    let open = false;
    const setOpen = (next: boolean) => {
      open = next;
      toggle.setAttribute('aria-expanded', String(next));
      menu.classList.toggle('-translate-x-full', !next);
      backdrop.classList.toggle('hidden', !next);
    };

    toggle.addEventListener(
      'click',
      (e) => {
        e.stopPropagation();
        setOpen(!open);
      },
      { signal },
    );
    backdrop.addEventListener('click', () => setOpen(false), { signal });
    menu.querySelectorAll('[data-nav-link]').forEach((link) =>
      link.addEventListener('click', () => setOpen(false), { signal }),
    );
    document.addEventListener(
      'keydown',
      (e) => {
        if (e.key === 'Escape') setOpen(false);
      },
      { signal },
    );
  }

  document.addEventListener('astro:page-load', setupNav);
</script>
