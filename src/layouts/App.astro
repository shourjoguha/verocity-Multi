---
import Base from './Base.astro';

interface Props {
  title?: string;
}

const { title = 'Verocity' } = Astro.props;
const path = Astro.url.pathname.replace(/\/+$/, '') || '/';
const links = [
  { href: '/app', label: 'Home' },
  { href: '/app/calendar', label: 'Calendar' },
  { href: '/app/stats', label: 'Stats' },
  { href: '/app/coach', label: 'Coach' },
  { href: '/app/plan', label: 'Plan' },
  { href: '/app/library', label: 'Library' },
  { href: '/app/shares', label: 'Share' },
];
const isActive = (href: string) => (href === '/app' ? path === '/app' : path.startsWith(href));
---

<Base title={title}>
  <a href="#main" class="skip-link">Skip to content</a>
  <header class="sticky top-0 z-50 border-b border-border bg-bg/90 backdrop-blur-md">
    <div class="mx-auto flex h-16 max-w-3xl items-center justify-between px-6">
      <a href="/app" class="font-display text-lg font-semibold uppercase tracking-tight text-fg">Verocity</a>
      <nav class="flex gap-5 text-[0.7rem] uppercase tracking-wider text-muted" aria-label="Primary">
        {
          links.map((l) => (
            <a
              href={l.href}
              aria-current={isActive(l.href) ? 'page' : undefined}
              class:list={['transition-colors duration-150 hover:text-fg', { 'text-fg': isActive(l.href) }]}
            >
              {l.label}
            </a>
          ))
        }
      </nav>
    </div>
  </header>
  <main id="main"><slot /></main>
</Base>
