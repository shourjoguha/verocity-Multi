---
import { ClientRouter } from 'astro:transitions';
import Toaster from '@/components/Toaster';
import BackgroundLayer from '@/components/BackgroundLayer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Verocity', description = 'Strength & training logger.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#f2f2f2" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icon.svg" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <!-- Clash Display + Satoshi (Fontshare). Self-host later for offline. -->
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&f[]=satoshi@400,500,700&display=swap"
    />
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
      // Apply the saved backdrop before first paint to avoid FOUC.
      (function () {
        try {
          var v = localStorage.getItem('verocity:bg');
          var allowed = ['off', 'grain', 'hairlines', 'topography', 'aurora'];
          if (allowed.indexOf(v) === -1) v = 'off';
          document.documentElement.setAttribute('data-bg', v);
        } catch (_) {
          document.documentElement.setAttribute('data-bg', 'off');
        }
      })();
    </script>
  </head>
  <body class="min-h-dvh">
    <BackgroundLayer />
    <slot />
    <Toaster client:load />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>
  </body>
</html>
