---
import { ClientRouter } from 'astro:transitions';
import Toaster from '@/components/Toaster';
import BackgroundLayer from '@/components/BackgroundLayer.astro';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  // Pages with their own bespoke backdrop (e.g. /login) can opt out of the
  // shared toggleable BackgroundLayer to avoid stacking two WebGL contexts.
  noBackdrop?: boolean;
}

const { title = 'Verocity', description = 'Strength & training logger.', noBackdrop = false } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#f2f2f2" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="apple-touch-icon" href="/icon.svg" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <!-- Clash Display + Satoshi (Fontshare). Self-host later for offline. -->
    <link rel="preconnect" href="https://api.fontshare.com" crossorigin />
    <link rel="preconnect" href="https://cdn.fontshare.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://api.fontshare.com/v2/css?f[]=clash-display@400,500,600,700&f[]=satoshi@400,500,700&display=swap"
    />
    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
      // Apply the saved theme before first paint (no flash). Preference is
      // 'light' | 'dark' | 'system'; 'system' (default) follows the OS and stays
      // live when it flips, re-dispatching verocity:theme-change so React
      // islands (the WebGL scenes) re-read. Mirrors src/lib/theme.ts.
      (function () {
        try {
          var KEY = 'verocity:theme';
          var pref = localStorage.getItem(KEY);
          if (pref !== 'light' && pref !== 'dark' && pref !== 'system') pref = 'system';
          var mql = window.matchMedia('(prefers-color-scheme: dark)');
          function paint(resolved) {
            document.documentElement.setAttribute('data-theme', resolved);
            document.documentElement.style.colorScheme = resolved;
            var m = document.querySelector('meta[name="theme-color"]');
            if (m) m.setAttribute('content', resolved === 'dark' ? '#0d0d0d' : '#f2f2f2');
          }
          paint(pref === 'dark' || (pref === 'system' && mql.matches) ? 'dark' : 'light');
          if (!window.__vTheme) {
            window.__vTheme = true;
            mql.addEventListener('change', function () {
              var p = localStorage.getItem(KEY);
              if (p === 'light' || p === 'dark') return; // manual pin ignores system
              var r = mql.matches ? 'dark' : 'light';
              paint(r);
              window.dispatchEvent(
                new CustomEvent('verocity:theme-change', { detail: { pref: 'system', resolved: r } }),
              );
            });
          }
        } catch (e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>
    <script is:inline>
      // Apply the saved backdrop before first paint to avoid FOUC. If no
      // explicit preference is stored, pick a device-aware default: desktops
      // with a fine pointer and no reduced-motion get the 3D scene; everyone
      // else gets the topography CSS preset (still a depth cue, no WebGL).
      (function () {
        try {
          var v = localStorage.getItem('verocity:bg');
          var allowed = ['off', 'grain', 'hairlines', 'topography', 'aurora'];
          if (allowed.indexOf(v) === -1) {
            var canBoot3D =
              window.matchMedia('(min-width: 768px) and (pointer: fine)').matches &&
              !window.matchMedia('(prefers-reduced-motion: reduce)').matches;
            v = canBoot3D ? 'aurora' : 'topography';
          }
          document.documentElement.setAttribute('data-bg', v);
        } catch (_) {
          document.documentElement.setAttribute('data-bg', 'topography');
        }
      })();
    </script>
  </head>
  <body class="min-h-dvh">
    {!noBackdrop && <BackgroundLayer />}
    <slot />
    <Toaster client:load />
    <script is:inline>
      if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
          navigator.serviceWorker.register('/sw.js').catch(() => {});
        });
      }
    </script>
  </body>
</html>
