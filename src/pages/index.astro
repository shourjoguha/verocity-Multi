---
import Base from '@/layouts/Base.astro';
---

<Base title="Verocity">
  <main class="mx-auto flex min-h-dvh max-w-3xl flex-col justify-center px-6">
    <p class="mb-4 text-xs uppercase tracking-[0.3em] text-muted">Strength · Training · Log</p>
    <h1
      class="font-display text-6xl font-semibold uppercase leading-[0.95] tracking-tight text-fg md:text-8xl"
    >
      Verocity
    </h1>
    <p class="mt-6 max-w-md text-subtle">
      A faster, multi-profile training logger. Private by default, with a read-only public
      showcase. Built on Astro islands and Supabase.
    </p>
    <div class="mt-10 flex items-center gap-3 text-sm">
      <a
        href="/app"
        class="inline-flex min-h-11 items-center bg-fg px-5 uppercase tracking-wider text-bg hover:bg-subtle"
        >Open app</a
      >
      <a
        href="/showcase"
        class="inline-flex min-h-11 items-center border border-border px-5 uppercase tracking-wider text-fg hover:border-subtle"
        >View showcase</a
      >
    </div>
  </main>
</Base>
