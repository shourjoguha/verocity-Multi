---
import Base from '@/layouts/Base.astro';
import LoginForm from '@/components/LoginForm';
import LoginHero from '@/components/LoginHero';
import { EchoText } from '@/components/EchoText';
---

<Base title="Sign in · Verocity" noBackdrop>
  <div class="login-hero" aria-hidden="true">
    <LoginHero client:idle />
  </div>
  <main class="relative z-10 mx-auto flex min-h-dvh max-w-sm flex-col justify-center px-6">
    <p class="mb-2 text-[0.7rem] uppercase tracking-[0.3em] text-muted">Verocity</p>
    <EchoText
      text="LOG IN"
      as="h1"
      className="mb-8 font-display text-5xl font-bold uppercase leading-[0.9] tracking-[-0.04em] text-fg md:text-6xl"
    />
    <LoginForm client:load />
    <p class="mt-6 text-xs text-muted">
      Invite-only. Have a code?{' '}
      <a href="/signup" class="text-fg underline hover:text-subtle">Sign up</a>.
    </p>
  </main>
</Base>

<style>
  .login-hero {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background: var(--color-bg);
  }
</style>
